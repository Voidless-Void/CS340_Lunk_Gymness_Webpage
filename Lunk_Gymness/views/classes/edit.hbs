<div class="page">
  <h1>Edit Class</h1>
  
  <form method="POST" action="/edit/classes/{{class.classID}}" class="form">
    <div class="form-group">
      <label for="className">Class Name:</label>
      <select id="className" name="className" value="{{class.className}}" required>
        <option value="Morning Yoga" {{#if (eq class.className "Morning Yoga")}}selected{{/if}}>Morning Yoga</option>
        <option value="Evening Yoga" {{#if (eq class.className "Evening Yoga")}}selected{{/if}}>Evening Yoga</option>
        <option value="HIIT Blast" {{#if (eq class.className "HIIT Blast")}}selected{{/if}}>HIIT Blast</option>
        <option value="Strength Training" {{#if (eq class.className "Strength Training")}}selected{{/if}}>Strength Training</option>
      </select>
    </div>
    
    <div class="form-group">
      <label for="scheduleTime">Schedule Time:</label>
      <input type="datetime-local" id="scheduleTime" name="scheduleTime" value="{{class.scheduleTime}}" required>
    </div>
    
    <div class="form-group">
      <label for="roomNumber">Room Number:</label>
      <select id="roomNumber" name="roomNumber" value="{{class.roomNumber}}">
        <option value="">Select Room</option>
        <option value="101" {{#if (eq class.roomNumber "101")}}selected{{/if}}>Room 101</option>
        <option value="102" {{#if (eq class.roomNumber "102")}}selected{{/if}}>Room 102</option>
        <option value="103" {{#if (eq class.roomNumber "103")}}selected{{/if}}>Room 103</option>
        <option value="104" {{#if (eq class.roomNumber "104")}}selected{{/if}}>Room 104</option>
      <select>
    </div>

    <div class="form-group">
      <label for="trainerID">Trainer:</label>
      <select id="trainerID" name="trainerID" required>
        <option value="">Select a trainer</option>
        {{#each trainers}}
        <option value="{{trainerID}}" {{#if (eq trainerID ../class.trainerID)}}selected{{/if}}>{{name}}</option>
        {{/each}}
      </select>
    </div>

    <div class="form-group">
      <label for="equipmentID">Equipment:</label>
      <select id="equipmentID" name="equipmentID" required>
        <option value="">Select equipment</option>
        {{#each equipment}}
        <option value="{{equipmentID}}" {{#if (eq equipmentID ../class.equipmentID)}}selected{{/if}}>{{equipmentName}}</option>
        {{/each}}
      </select>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Update Class</button>
      <a href="/classes" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>

