<div class="page">
  <h1>Edit Class</h1>
  
  <form method="POST" action="/classes/edit/{{class.classID}}" class="form">
    <div class="form-group">
      <label for="className">Class Name:</label>
      <input type="text" id="className" name="className" value="{{class.className}}" required>
    </div>
    
    <div class="form-group">
      <label for="scheduleTime">Schedule Time:</label>
      <input type="datetime-local" id="scheduleTime" name="scheduleTime" value="{{class.scheduleTime}}" required>
    </div>
    
    <div class="form-group">
      <label for="roomNumber">Room Number:</label>
      <input type="text" id="roomNumber" name="roomNumber" value="{{class.roomNumber}}">
    </div>

    <div class="form-group">
      <label for="capacity">Capacity:</label>
      <input type="number" id="capacity" name="capacity" value="{{class.capacity}}" min="1">
    </div>

    <div class="form-group">
      <label for="trainerID">Trainer ID:</label>
      <input type="number" id="trainerID" name="trainerID" value="{{class.trainerID}}">
    </div>

    <div class="form-group">
      <label for="equipmentID">Equipment ID:</label>
      <input type="number" id="equipmentID" name="equipmentID" value="{{class.equipmentID}}">
    </div>
    
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Update Class</button>
      <a href="/classes" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>

