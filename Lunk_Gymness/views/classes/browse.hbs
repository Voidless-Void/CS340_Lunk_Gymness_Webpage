<div class="page">
  <h1>Classes</h1>
  
  <a href="/classes/add" class="btn btn-primary">Add New Class</a>
  
  {{#if classes}}
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Class Name</th>
          <th>Schedule Time</th>
          <th>Room</th>
          <th>Capacity</th>
          <th>Trainer ID</th>
          <th>Equipment ID</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each classes}}
          <tr>
            <td>{{this.classID}}</td>
            <td>{{this.className}}</td>
            <td>{{this.scheduleTime}}</td>
            <td>{{this.roomNumber}}</td>
            <td>{{this.capacity}}</td>
            <td>{{this.trainerID}}</td>
            <td>{{this.equipmentID}}</td>
            <td>
              <a href="/classes/edit/{{this.classID}}" class="btn btn-small btn-edit">Edit</a>
              <form method="POST" action="/classes/delete/{{this.classID}}" style="display:inline;">
                <button type="submit" class="btn btn-small btn-delete" onclick="return confirm('Are you sure?')">Delete</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>No classes found. <a href="/classes/add">Add a new class</a></p>
  {{/if}}
</div>

