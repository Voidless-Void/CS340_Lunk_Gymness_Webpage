<div class="page">
  <h1>Equipment Inventory</h1>
  
  <a href="/equipment/add" class="btn btn-primary">Add New Equipment</a>
  
  {{#if equipment}}
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Category</th>
          <th>Condition</th>
          <th>Maintenance Date</th>
          <th style="width: 100px;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each equipment}}
          <tr>
            <td>{{this.equipmentID}}</td>
            <td>{{this.equipmentName}}</td>
            <td>{{this.category}}</td>
            <td>{{this.condition}}</td>
            <td>{{this.maintenanceDate}}</td>
            <td>
              <a href="/equipment/edit/{{this.equipmentID}}" class="btn btn-small btn-edit">Edit</a>
              <a href="/delete/equipment/{{this.equipmentID}}" class="btn btn-small btn-delete" onclick="return confirm('Are you sure?')">Delete</a>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>No equipment found. <a href="/equipment/add">Add some equipment</a></p>
  {{/if}}
</div>
