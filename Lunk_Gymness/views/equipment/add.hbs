<div class="page">
  <h1>Add New Equipment</h1>
  
  <form method="POST" action="/equipment" class="form">
    <div class="form-group">
      <label for="equipmentName">Equipment Name:</label>
      <input type="text" id="equipmentName" name="equipmentName" required>
    </div>
    
    <div class="form-group">
      <label for="category">Category:</label>
      <input type="text" id="category" name="category" required>
    </div>
    
    <div class="form-group">
      <label for="condition">Condition:</label>
      <select id="condition" name="condition" required>
        <option value="">Select Condition</option>
        <option value="Good">Good</option>
        <option value="Fair">Fair</option>
        <option value="Needs Repair">Needs Repair</option>
      </select>
    </div>
    
    <div class="form-group">
      <label for="maintenanceDate">Maintenance Date:</label>
      <input type="date" id="maintenanceDate" name="maintenanceDate">
    </div>
    
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Add Equipment</button>
      <a href="/equipment" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
