<div class="page">
  <h1>Edit Class Registration</h1>
  
  <form method="POST" action="/edit/classregistrations/{{registration.classRegID}}" class="form">

    <div class="form-group">
      <label for="memberID">Member:</label>
      <select id="memberID" name="memberID" required>
        <option value="">Select a member</option>
        {{#each members}}
        <option value="{{memberID}}" {{#if (eq memberID ../registration.memberID)}}selected{{/if}}>{{name}}</option>
        {{/each}}
      </select>
    </div>
    
    <div class="form-group">
      <label for="classID">Class:</label>
      <select id="classID" name="classID" required>
        <option value="">Select a class</option>
        {{#each classes}}
        <option value="{{classID}}" {{#if (eq classID ../registration.classID)}}selected{{/if}}>{{className}} - {{scheduleTime}}</option>
        {{/each}}
      </select>
    </div>
    
    <div class="form-group">
      <label for="registrationDate">Registration Date:</label>
      <input type="date" id="registrationDate" name="registrationDate" value="{{registration.registrationDate}}" required>
    </div>

    <div class="form-group">
      <label for="classType">Class Type:</label>
      <select id="classType" name="classType" value="{{registration.classType}}">
        <option value=""> Select class type</option>
        <option value="Yoga" {{#if (eq registration.classType "Yoga")}}selected{{/if}}>Yoga</option>
        <option value="Strength" {{#if (eq registration.classType "Strength")}}selected{{/if}}>Spin</option>
        <option value="Cardio" {{#if (eq registration.classType "Cardio")}}selected{{/if}}>Cardio</option>
      </select>
    </div>
    
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Update a Class Registration</button>
      <a href="/classregistrations" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
