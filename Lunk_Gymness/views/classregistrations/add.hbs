<div class="page">
  <h1>New Class Registration</h1>
  
  <form method="POST" action="/classregistrations" class="form">
    <div class="form-group">
      <label for="classregID">Registration ID:</label>
      <input type="text" id="classregID" name="classregID" required>
    </div>

    <div class="form-group">
      <label for="memberID">Member ID:</label>
      <input type="text" id="memberID" name="memberID" required>
    </div>
    
    <div class="form-group">
      <label for="classID">Class ID:</label>
      <input type="text" id="classID" name="classID" required>
    </div>
    
    <div class="form-group">
      <label for="registrationDate">Registration Date:</label>
      <input type="date" id="registrationDate" name="registrationDate" required>
    </div>

    <div class="form-group">
      <label for="classType">Class Type:</label>
      <input type="text" id="classType" name="classType" placeholder="e.g. In-person, Virtual">
    </div>
    
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Add Class Registration</button>
      <a href="/classregistrations" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>