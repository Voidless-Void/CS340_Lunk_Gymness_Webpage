<div class="page">
  <h1>Edit Trainer</h1>
  
  <form method="POST" action="/edit/trainers/{{trainer.trainerID}}" class="form">
    <div class="form-group">
      <label for="firstName">First Name:</label>
      <input type="text" id="firstName" name="firstName" value="{{trainer.firstName}}" required>
    </div>
    
    <div class="form-group">
      <label for="lastName">Last Name:</label>
      <input type="text" id="lastName" name="lastName" value="{{trainer.lastName}}" required>
    </div>
    
    <div class="form-group">
      <label for="biography">Biography:</label>
      <input type="text" id="biography" name="biography" value="{{trainer.biography}}" placeholder="Brief description of the trainer's experience, qualifications, and specialties">
    </div>
    
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Update Trainer</button>
      <a href="/trainers" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
