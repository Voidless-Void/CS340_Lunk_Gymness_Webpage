<div class="page">
  <h1>Trainers</h1>
  
  <a class="btn btn-primary">Add New Trainer</a>
  
  {{#if trainers}}
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>First Name</th>
          <th>Last Name</th>
          <th>Specialty</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each trainers}}
          <tr>
            <td>{{this.trainerID}}</td>
            <td>{{this.firstName}}</td>
            <td>{{this.lastName}}</td>
            <td>{{this.specialty}}</td>
            <td>
              <a class="btn btn-small btn-edit">Edit</a>
              <form style="display:inline;">
                <button type="submit" class="btn btn-small btn-delete" onclick="return confirm('Are you sure?')">Delete</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>No trainers found. <a>Add a new trainer</a></p>
  {{/if}}
</div>
